# FinSight-AI Root Gitignore

# Project Plans
implementation_plan.md

# IDEs and System Files
.idea/
.vscode/
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db

# Backend (Spring Boot / Maven)
finsight-backend/target/
finsight-backend/.mvn/wrapper/maven-wrapper.jar
finsight-backend/HELP.md
.apt_generated/
.classpath
.factorypath
.project
.settings/
.springBeans/
.sts4-cache/
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/

# Frontend (Next.js / Node)
finsight-frontend/node_modules/
finsight-frontend/.next/
finsight-frontend/out/
finsight-frontend/build/
finsight-frontend/next-env.d.ts
finsight-frontend/*.tsbuildinfo
finsight-frontend/.pnp
finsight-frontend/.pnp.*
finsight-frontend/.yarn/*
!finsight-frontend/.yarn/patches
!finsight-frontend/.yarn/plugins
!finsight-frontend/.yarn/releases
!finsight-frontend/.yarn/versions

# Environment and Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
